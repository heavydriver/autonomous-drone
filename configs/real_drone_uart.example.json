  "runtime": {
    "dry_run": false,
    "skip_rc_gate": false,
    "visualize": true,
    "video_source": "PASTE_YOUR_CAMERA_DEVICE_OR_GSTREAMER_PIPELINE_HERE",
    "video_backend": "auto",
    "model_device": "cpu"
  }
