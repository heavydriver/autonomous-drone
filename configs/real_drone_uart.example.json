{
  "camera": {
    "mount_pitch_deg": 10.0
  },
  "mavlink": {
    "transport": "serial",
    "serial_device": "/dev/ttyYOUR_UART_DEVICE",
    "baud_rate": 921600,
    "follow_enable_channel": 7,
    "follow_enable_high_pwm": 1800,
    "alt_hold_use_rc_overrides": true,
    "rc_override_roll_channel": 1,
    "rc_override_pitch_channel": 2,
    "rc_override_throttle_channel": 3,
    "rc_override_yaw_channel": 4,
    "guided_mode_name": "GUIDED",
    "stream_rate_hz": 10
  },
  "tracking": {
    "model_path": "/absolute/path/to/your/yolo_model.pt",
    "detector_confidence": 0.4,
    "min_box_area_ratio": 0.015,
    "desired_box_area_ratio": 0.08,
    "emergency_stop_area_ratio": 0.18,
    "loss_timeout_s": 0.6,
    "acquisition_confirm_frames": 3,
    "tracker_frame_rate": 10.0,
    "tracker_track_buffer": 30,
    "tracker_match_thresh": 0.8
  },
  "control": {
    "loop_rate_hz": 10.0,
    "horizontal_angle_filter_alpha": 0.25,
    "box_area_filter_alpha": 0.18,
    "yaw_gain": 1.0,
    "forward_gain": 6.0,
    "lateral_gain": 0.0,
    "yaw_deadband_deg": 4.0,
    "horizontal_alignment_window_deg": 10.0,
    "box_area_deadband_ratio": 0.012,
    "max_forward_speed_m_s": 0.8,
    "max_reverse_speed_m_s": 0.2,
    "max_lateral_speed_m_s": 0.15,
    "max_vertical_speed_m_s": 0.0,
    "max_yaw_rate_deg_s": 12.0,
    "speed_slew_limit_m_s2": 0.35,
    "yaw_slew_limit_deg_s2": 30.0,
    "vertical_slowdown_angle_deg": 18.0,
    "enable_lateral_motion": false
  },
  "safety": {
    "stand_off_distance_m": 4.0,
    "hold_altitude_m": 2.4,
    "max_roll_pitch_deg": 10.0
  },
  "pose": {
    "hand_raise_circle_enabled": false,
    "model_path": "/absolute/path/to/your/yolo11n-pose.pt",
    "inference_interval_s": 7.0,
    "min_bbox_area_ratio": 0.01,
    "crop_margin_ratio": 0.12,
    "min_keypoint_confidence": 0.35,
    "wrist_above_shoulder_margin_ratio": 0.05,
    "wrist_above_elbow_margin_ratio": 0.02,
    "max_wrist_shoulder_offset_ratio": 0.35,
    "trigger_cooldown_s": 10.0
  },
  "orbit": {
    "clockwise": true,
    "lateral_speed_m_s": 0.4,
    "forward_correction_gain": 4.0,
    "max_forward_correction_m_s": 0.3,
    "yaw_gain": 1.2,
    "max_yaw_rate_deg_s": 18.0,
    "completion_angle_deg": 360.0,
    "max_duration_s": 90.0
